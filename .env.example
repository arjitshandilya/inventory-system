# Copy this file to .env in the project root and adjust as needed.
# docker-compose reads this automatically. Never commit the real .env file.

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_use_a_strong_password
POSTGRES_DB=inventory_db
POSTGRES_PORT=5432

# --- Backend ---
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
ENVIRONMENT=development
LOW_STOCK_THRESHOLD=10

# --- Frontend ---
FRONTEND_PORT=5173
# Must match wherever the backend is reachable from the browser.
# For local docker-compose use, http://localhost:8000 is correct because
# the browser calls the backend's published port directly.
VITE_API_URL=http://localhost:8000
